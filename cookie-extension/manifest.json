{
  "manifest_version": 3,
  "name": "Job Site Cookie Exporter",
  "version": "1.0.0",
  "description": "Export bossjob.us or linkedin.com cookies to your job scraper dashboard",
  "permissions": [
    "cookies",
    "activeTab",
    "storage",
    "tabs",
    "debugger"
  ],
  "host_permissions": [
    "https://bossjob.us/*",
    "https://linkedin.com/*",
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
